{
  "appId": "com.discord.workspace.manager",
  "productName": "Discord Workspace Manager",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "package.json"
  ],
  "win": {
    "target": "nsis",
    "icon": "public/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
